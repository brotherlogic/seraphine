// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "Beerkellar",
	"image": "mcr.microsoft.com/devcontainers/base:noble",
	"features": {
		"ghcr.io/devcontainers/features/go:1": {},
		"ghcr.io/nils-geistmann/devcontainers-features/zsh:0": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/siri404/devcontainer-ai-features/gemini-cli:1": {},
		"ghcr.io/devcontainers/features/common-utils": "2",
		"ghcr.io/devcontainers-extra/features/protoc:1": {}
	},
    	"customizations": {
		"vscode": {
			"extensions": [
				"golang.Go",
				"davidanson.vscode-markdownlint"
			]
		}
	},
	"postCreateCommand": "./postCreate.sh",
	"workspaceFolder": "/workspaces/seraphine",
	"workingDir": "/workspaces/seraphine",
	"initializeCommand": "echo \"GH_TOKEN=$(gh auth token)\" > .devcontainer/.env.auth",
	"runArgs": [
		"--security-opt",
		"label=disable"
	],
	"containerEnv": {
		"GH_GIT_PROTOCOL": "ssh"
	},
	"mounts": [
		{
			"source": "${localEnv:HOME}/.agent-ssh",
			"target": "/home/vscode/.ssh", 
			"type": "bind",
			"options": "readonly" 
		}
	]
}
